{
  "version": "2026-03-v1",
  "description": "总表入库字段注册 + 电价预测V1任务可得性与防泄漏规则",
  "forecast_task_policies": {
    "dayahead": {
      "forbidden_feature_prefixes": [
        "price_realtime_jn_final",
        "price_realtime_jb_final",
        "price_realtime_jn_node",
        "price_realtime_jb_node",
        "price_realtime_weighted_public"
      ],
      "drop_unknown_features": true
    },
    "realtime": {
      "forbidden_feature_prefixes": [],
      "drop_unknown_features": true
    }
  },
  "availability_rules": {
    "dayahead_dminus1_0930": {
      "type": "fixed_day_offset",
      "day_offset": -1,
      "time_hhmm": "09:30",
      "description": "D日该值在D-1 09:30可得"
    },
    "dayahead_dminus1_1700": {
      "type": "fixed_day_offset",
      "day_offset": -1,
      "time_hhmm": "17:00",
      "description": "D日该值在D-1 17:00可得"
    },
    "realtime_delay_1h": {
      "type": "delay_from_value_ts",
      "delay_minutes": 60,
      "description": "该时点值在事件后1小时可得"
    }
  },
  "availability_by_metric_prefix": {
    "receive_plan_boundary": "dayahead_dminus1_0930",
    "load_forecast_boundary": "dayahead_dminus1_0930",
    "reserve_positive": "dayahead_dminus1_0930",
